# Root .env example – copy to .env and fill in real values
# ------------------------------------------------------------------

# network / ports
CLIENT_PORT=5173              # Vite dev port (dev only)
SERVER_PORT=3001              # Express port
VITE_API_URL=http://localhost:3001   # set by dev compose automatically

# common / runtime
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# server (Express)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# literal \n newlines in the key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# alternative to the 3 vars above:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":...}

# client (Vite) – only used at build time
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
